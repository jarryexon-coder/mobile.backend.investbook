{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest",
        "resourceClass": "default"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest",
        "resourceClass": "default"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "resourceClass": "default",
        "buildProperties": {
          "workspace": "ios/mobilefixed.xcworkspace",
          "scheme": "mobilefixed"
        }
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jarryexon@gmail.com"
      }
    }
  }
}
