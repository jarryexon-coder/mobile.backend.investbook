{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "RCT_NO_LAUNCH_PACKAGER": "true",
        "EXPO_USE_HERMES": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jarryexon@gmail.com"
      }
    }
  }
}
