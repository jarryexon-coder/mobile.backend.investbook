{
  "expo": {
    "name": "InvestBook Pro",
    "slug": "investbook-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jerryjiya.investbookpro",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "InvestBook Pro uses your location to show nearby investment opportunities.",
        "NSPhotoLibraryUsageDescription": "InvestBook Pro uses your photo library to upload property images.",
        "NSCameraUsageDescription": "InvestBook Pro uses your camera to take photos of properties."
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.jerryjiya.investbookpro",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "icon": "./assets/icon.png"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "InvestBook Pro",
      "shortName": "InvestBook Pro",
      "description": "Discover and invest in real estate and business opportunities."
    },
    "extra": {
      "eas": {
        "projectId": "49db4bae-9e3d-44f2-bd9e-8f663b50bad5"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
